  m_Script: {fileID: 11500000, guid: 87af5721ba275334a9c76ddb55d03e10, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Prolouge
  prologueTxt: {fileID: 1112778084}
  prolougeTextSpeed: 0.05
  isTyping: 0
  isPrologueFinished: 1
  prologueLines:
  - speakerName: Narrator
    dialougeTxt: It's a beautiful Saturday night. You and your friends decided to
      have a small party at Ravi's apartment.
  - speakerName: Narrator
    dialougeTxt: 'The music was loud, laughter echoed through the room. '
  - speakerName: Narrator
    dialougeTxt: 'As the night went on, you and the rest of the gang gathered in
      the living room, playing Monopoly. '
  - speakerName: Narrator
    dialougeTxt: 'A strange message appeared on every screen in the world: HIDE!'
  - speakerName: Narrator
    dialougeTxt: You stared with confusion at your phone.
